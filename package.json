{
	"name": "create-next-strict",
	"version": "2.1.0",
	"description": "Wrap Create Next App in Strict Defaults",
	"homepage": "https://github.com/seanhealy/create-next-strict#readme",
	"bugs": {
		"url": "https://github.com/seanhealy/create-next-strict/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/seanhealy/create-next-strict.git"
	},
	"license": "MIT",
	"author": "Sean Healy",
	"type": "module",
	"bin": {
		"create-next-strict": "setup-next.js"
	},
	"files": [
		"setup-next.js",
		"templates",
		"LICENSE",
		"README.md"
	],
	"keywords": [
		"next",
		"nextjs",
		"create-next-app",
		"biome",
		"drizzle",
		"neon",
		"strict",
		"scaffold"
	],
	"scripts": {
		"start": "node setup-next.js",
		"lint": "biome check && prettier --check .",
		"format": "biome check --write",
		"lint:fix": "biome check --write && prettier --write .",
		"test": "node setup-next.js --dry-run",
		"test:seed": "mkdir -p test-app && cd test-app && node ../setup-next.js",
		"test:clean": "rm -rf test-app"
	},
	"volta": {
		"node": "24.10.0",
		"npm": "11.6.2"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.7",
		"prettier": "^3.8.1"
	}
}
